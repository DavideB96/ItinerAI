generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String      @id @default(cuid())
  email       String      @unique
  password    String
  name        String?
  interests   String?
  city        String?
  createdAt   DateTime    @default(now())
  itineraries Itinerary[]
}

model Itinerary {
  id          String   @id @default(cuid())
  destination String
  days        Int
  budget      String
  interests   String?
  content     Json
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
}